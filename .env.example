# C>Connect — backend config (Supabase).
# Copy to .env.local for local dev, and set the same two vars in
# Vercel → Project → Settings → Environment Variables for production.
#
# Find these in your Supabase project: Settings → API.
# The anon key is safe to expose in the client (RLS is the security boundary).
# Leave these unset to run the app in demo mode (no backend, mock data).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
